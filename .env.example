# Supabase (Project settings -> API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only, never expose

# Resend (resend.com -> API keys)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM=Matchmaker <hello@yourdomain.com>       # must be a Resend-verified domain

# A long random string. Vercel sends it as a Bearer token to protect the cron.
CRON_SECRET=change-me-to-a-long-random-string

# Public base URL of the deployed app (used in confirmation links)
APP_URL=https://your-app.vercel.app
